# Streamlit Secrets Configuration Example
# 
# HOW TO USE:
# 1. Create a local file: .streamlit/secrets.toml
# 2. Copy this template and fill in your actual credentials
# 3. NEVER commit secrets.toml to GitHub - add it to .gitignore
# 4. For Streamlit Cloud deployment, add secrets via the app settings UI
#
# SECURITY BEST PRACTICES:
# - Never share your API keys publicly
# - Revoke exposed keys immediately on Kraken
# - Use IP whitelisting in Kraken API settings
# - Restrict API key permissions (no fund withdrawal)
# - Store credentials ONLY in Streamlit Secrets or environment variables

[kraken]
api_key = "YOUR_KRAKEN_API_KEY_HERE"
secret_key = "YOUR_KRAKEN_SECRET_KEY_HERE"
